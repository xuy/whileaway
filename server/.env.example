# whileaway bus — copy to .env and tweak. All values are optional; defaults work out of the box.

# Port the bus listens on.
PORT=4000

# Publisher key used by the bundled reference pushers (and any external pusher you run).
# If unset, the bus mints an ephemeral one on each boot and prints it. Set a stable value so
# external pushers keep working across restarts. Generate one with: openssl rand -hex 18
WHILEAWAY_KEY=

# Where to persist channels/items/subscriptions/history. Defaults to ./.whileaway-state.json
# WHILEAWAY_STATE=./.whileaway-state.json

# Storage driver: "json" (default, self-host) or "sqlite" (hosted). SQLite uses WHILEAWAY_STATE
# as the .db path. Switching to sqlite? run `npm run migrate:sqlite <state.json> <out.db>` first.
# WHILEAWAY_STORE=json

# --- Hosted mode (a public multi-user instance) --------------------------------------------
# Self-host leaves these unset (AUTH_MODE defaults to "none"). For a hosted deploy:
#   AUTH_MODE=hosted                 # dashboard login + per-user tokens; header identity no longer trusted
#   WHILEAWAY_URL=https://your-host  # public base URL (used as the auth baseURL)
#   WHILEAWAY_AUTH_SECRET=...        # REQUIRED in prod — openssl rand -hex 32
#   WHILEAWAY_AUTH_DB=./.whileaway-auth.db   # Better Auth's own tables (run `npm run auth:migrate` first)
# Optional Google sign-in (magic link works without it; a real email sender is wired later):
#   WHILEAWAY_GOOGLE_CLIENT_ID=...
#   WHILEAWAY_GOOGLE_CLIENT_SECRET=...

# Rate limits / caps (defaults are generous; normal single-user usage never trips them):
# WHILEAWAY_PUSH_PER_MIN=60   WHILEAWAY_PULL_PER_MIN=120   WHILEAWAY_MAX_LANES=50   WHILEAWAY_MAX_ITEMS=10000

# Set to 0 to NOT run the bundled reference pushers in-process (e.g. you run `npm run pushers`
# separately, or push from your own clients). Default: pushers run in-process for a zero-setup demo.
RUN_DEFAULT_PUSHERS=1

# How often the reference pushers pull their sources and push fresh items (ms). Default 10 min.
# PUSH_INTERVAL_MS=600000

# RSS/Atom feed URLs for the bundled `rss` pusher. Falls back to sensible defaults.
# FEED_RSS=https://hnrss.org/frontpage,https://www.theverge.com/rss/index.xml
