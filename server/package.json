{
  "name": "whileaway-server",
  "version": "0.1.0",
  "description": "whileaway backend — queues ambient content (Wikipedia, HN, RSS, Reddit, personal mocks) to deliver while you wait for an AI to answer.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "pushers": "node clients/runner.js",
    "migrate:sqlite": "node scripts/migrate-json-to-sqlite.js",
    "test": "WHILEAWAY_STATE=.whileaway-test-state.json node --test",
    "test:sqlite": "WHILEAWAY_STORE=sqlite WHILEAWAY_STATE=.whileaway-test.db node --test --test-concurrency=1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^4.21.2"
  }
}
